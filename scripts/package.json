  "scripts": {
    "prepare": "node -e \"if (process.env.CF_PAGES || process.env.CLOUDFLARE) process.exit(0); process.exit(require('child_process').spawnSync('effect-language-service', ['patch'], { stdio: 'inherit', shell: true }).status ?? 1)\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
