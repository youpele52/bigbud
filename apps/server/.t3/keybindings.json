[
  {
    "key": "mod+j",
    "command": "terminal.toggle"
  },
  {
    "key": "mod+d",
    "command": "terminal.split",
    "when": "terminalFocus"
  },
  {
    "key": "mod+n",
    "command": "terminal.new",
    "when": "terminalFocus"
  },
  {
    "key": "mod+w",
    "command": "terminal.close",
    "when": "terminalFocus"
  },
  {
    "key": "mod+n",
    "command": "chat.new",
    "when": "!terminalFocus"
  },
  {
    "key": "mod+shift+o",
    "command": "chat.new",
    "when": "!terminalFocus"
  },
  {
    "key": "mod+shift+n",
    "command": "chat.newLocal",
    "when": "!terminalFocus"
  },
  {
    "key": "mod+o",
    "command": "editor.openFavorite"
  },
  {
    "key": "mod+d",
    "command": "diff.toggle",
    "when": "!terminalFocus"
  }
]
