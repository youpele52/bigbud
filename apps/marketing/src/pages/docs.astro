---
import docsContent from "../components/page-specific/docs/_docs-content.md?raw";

import MarkdownRenderer from "../components/shared/markdown-renderer/MarkdownRenderer.astro";
import { DOCS_METADATA } from "../constants/seo";
import {
  buildBreadcrumbSchema,
  buildOrganizationSchema,
  buildSoftwareApplicationSchema,
  buildWebPageSchema,
  buildWebsiteSchema,
} from "../lib/structuredData";
import Layout from "../layouts/Layout.astro";
import "./docs.css";

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? Astro.url.origin;
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();
const structuredData = [
  buildOrganizationSchema({ pageUrl, siteUrl }),
  buildWebsiteSchema({ pageUrl, siteUrl }),
  buildSoftwareApplicationSchema({ pageUrl, siteUrl }),
  buildWebPageSchema({ pageUrl, siteUrl }, DOCS_METADATA.title, DOCS_METADATA.description),
  buildBreadcrumbSchema(pageUrl, "Docs", siteUrl),
];
---

<Layout {...DOCS_METADATA} structuredData={structuredData}>
  <section class="docs-page">
    <MarkdownRenderer content={docsContent} />
  </section>
</Layout>
