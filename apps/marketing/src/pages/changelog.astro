---
import changelogContent from "../../../../docs/CHANGELOG.md?raw";

import ChangelogSeoSummary from "../components/page-specific/changelog/ChangelogSeoSummary.astro";
import MarkdownRenderer from "../components/shared/markdown-renderer/MarkdownRenderer.astro";
import { CHANGELOG_METADATA } from "../constants/seo";
import { buildChangelogFaq, summarizeChangelog } from "../lib/changelogSeo";
import {
  buildBreadcrumbSchema,
  buildOrganizationSchema,
  buildSoftwareApplicationSchema,
  buildWebsiteSchema,
} from "../lib/structuredData";
import Layout from "../layouts/Layout.astro";
import "./changelog.css";

const summary = summarizeChangelog(changelogContent);
const faqs = buildChangelogFaq(summary);
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? Astro.url.origin;
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();
const latestReleaseLabel = summary.latestRelease
  ? `${summary.latestRelease.version} (${summary.latestRelease.publishedAt})`
  : "Latest release";
const latestTopics = summary.latestRelease?.sections.slice(0, 4) ?? [
  "AI workflow improvements",
  "provider updates",
  "reliability fixes",
];
const recurringTopics = summary.recurringTopics.slice(0, 5);
const changelogDescription = summary.latestRelease
  ? `Read the ${CHANGELOG_METADATA.title.replace(" | bigbud", "")} for ${summary.latestRelease.version} and browse ${summary.releaseCount} documented bigbud releases covering AI providers, browser workflows, git tooling, automation, and reliability improvements.`
  : CHANGELOG_METADATA.description;
const structuredData = [
  buildOrganizationSchema({ pageUrl, siteUrl }),
  buildWebsiteSchema({ pageUrl, siteUrl }),
  buildSoftwareApplicationSchema({ pageUrl, siteUrl }),
  buildBreadcrumbSchema(pageUrl, "Changelog", siteUrl),
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "bigbud changelog",
    url: pageUrl,
    description: changelogDescription,
    isPartOf: siteUrl,
    about: {
      "@type": "SoftwareApplication",
      name: "bigbud",
    },
    dateModified: summary.latestRelease?.isoDate ?? undefined,
    mainEntity: {
      "@type": "ItemList",
      itemListElement: summary.latestRelease
        ? latestTopics.map((topic, index) => ({
            "@type": "ListItem",
            position: index + 1,
            name: topic,
          }))
        : undefined,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
      "@type": "Question",
      name: faq.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: faq.answer,
      },
    })),
  },
];
---

<Layout
  {...CHANGELOG_METADATA}
  description={changelogDescription}
  structuredData={structuredData}
>
  <section class="changelog-page">
    <ChangelogSeoSummary
      latestReleaseLabel={latestReleaseLabel}
      releaseCount={summary.releaseCount}
      dateRangeLabel={summary.dateRangeLabel}
      latestTopics={latestTopics}
      recurringTopics={recurringTopics}
      faqs={faqs}
    />
    <MarkdownRenderer content={changelogContent} />
  </section>
</Layout>
