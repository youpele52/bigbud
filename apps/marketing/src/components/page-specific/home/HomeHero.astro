---
import { APP_NAME, MARKETING_ASSETS } from "../../../constants/app";
import { HOME_METADATA } from "../../../constants/seo";
import Button from "../../shared/Button.astro";
import PlatformIcon from "../../shared/PlatformIcon.astro";
import "./HomeHero.css";
import "./HomeHero.visual.css";

const showcaseFeatures = [
    {
        title: "Everything you're working on, in one place.",
        description:
            "Move between projects, chats, and ideas without losing the thread.",
        image: "/screenshots/one-workspace.webp",
    },
    {
        title: "Look things up without breaking focus.",
        description:
            "Browse, research, and pull what you need into your work — all without leaving the workspace.",
        images: [
            "/screenshots/research-slide-1.webp",
            "/screenshots/research-slide-2.webp",
        ],
    },
    {
        title: "Use the right AI for the step you're on.",
        description:
            "Switch between providers, harnesses, and models — so you're never stuck with just one.",
        image: "/screenshots/switch-ai.webp",
        showProviderDrop: true,
    },
    {
        title: "Stay in control as your work evolves.",
        description:
            "Review every change, keep longer projects on track, and always know what moved.",
        images: [
            "/screenshots/stay-in-control-slide-1.webp",
            "/screenshots/stay-in-control-2.webp",
        ],
    },
    {
        title: "Pick up where you left off.",
        description:
            "Threads, context, and progress are always there when you return.",
        image: "/screenshots/pick-up-where-you-left.webp",
    },
] as const;

const providerDrops = [
    { icon: "/provider-icons/claude.svg" },
    { icon: "/provider-icons/codex.svg" },
    { icon: "/provider-icons/copilot.svg" },
    { icon: "/provider-icons/cursor.svg" },
    { icon: "/provider-icons/devin.svg" },
    { icon: "/provider-icons/kilocode.svg" },
    { icon: "/provider-icons/opencode.svg" },
    { icon: "/provider-icons/pi.svg" },
] as const;
---

<div class="hero-stack">
    <section class="hero-copy" aria-label="Introduction">
        <div class="hero-copy-body">
            <div class="hero-brand">
                <img
                    src={MARKETING_ASSETS.navLogoPath}
                    alt={APP_NAME}
                    class="hero-brand-icon"
                />
                <span class="hero-brand-name">{APP_NAME}</span>
            </div>
            <h1 class="tagline">
                <span class="tagline-line"><span class="tagline-word">all</span> <span class="tagline-word">your</span> <span class="tagline-word">work.</span></span>
                <span class="tagline-line"><span class="tagline-word">one</span> <span class="tagline-word">workspace.</span></span>
            </h1>
            <p class="tagline-copy">
                bigbud brings your projects, ideas, and creative work into one
                place. Stay in flow, get help when you need it, and keep moving
                without losing where you left off.
            </p>
            <p class="tagline-copy">
                Made for work that changes shape as you go.
            </p>

            <div class="hero-actions">
                <Button
                    id="download-btn"
                    href="/download"
                    class="hero-button"
                    aria-label="Download latest release"
                >
                    <PlatformIcon
                        platform="apple"
                        class="hero-button-icon hero-button-icon--apple"
                    />
                    <PlatformIcon
                        platform="windows"
                        class="hero-button-icon hero-button-icon--windows"
                    />
                    <PlatformIcon
                        platform="linux"
                        class="hero-button-icon hero-button-icon--linux"
                    />
                    <span id="download-label">Download</span>
                </Button>

                <a href="/download" class="other-platforms">Other platforms</a>
            </div>
        </div>
    </section>

    <section class="hero-visual" aria-hidden="true">
        <div class="visual-frame">
            <img
                src={MARKETING_ASSETS.homepageScreenshotPath}
                alt={HOME_METADATA.imageAlt}
                class="screenshot"
                onload="this.classList.add('is-loaded')"
            />
        </div>
    </section>

    <section class="hero-features" aria-labelledby="hero-features-heading">
        <div class="hero-features-inner">
            <h2 id="hero-features-heading" class="hero-features-heading">
                built for work that keeps moving.
            </h2>
            <div class="feature-showcases">
                {
                    showcaseFeatures.map((feature) => (
                        <div
                            class:list={[
                                "feature-showcase",
                                "showProviderDrop" in feature &&
                                    "feature-showcase--with-drop",
                            ]}
                        >
                            <div class="feature-showcase-content">
                                <h3 class="showcase-title">
                                    {feature.title}
                                </h3>
                                <p class="showcase-desc">
                                    {feature.description}
                                </p>
                            </div>
                            {
                                "images" in feature ? (
                                    <div
                                        class="feature-showcase-visual feature-showcase-slider"
                                        data-animate="dissolve"
                                    >
                                        <div class="slider-track">
                                            {feature.images.map((src) => (
                                                <img
                                                    src={src}
                                                    alt={feature.title}
                                                    loading="lazy"
                                                />
                                            ))}
                                        </div>
                                    </div>
                                ) : (
                                    <div
                                        class="feature-showcase-visual"
                                        data-animate="dissolve"
                                    >
                                        <img
                                            src={feature.image}
                                            alt={feature.title}
                                            loading="lazy"
                                        />
                                    </div>
                                )
                            }
                            {
                                "showProviderDrop" in feature && (
                                    <div
                                        class="provider-drop-stage"
                                        aria-hidden="true"
                                    >
                                        {providerDrops.map((provider) => (
                                            <div
                                                class="provider-drop-logo"
                                            >
                                                <img
                                                    src={provider.icon}
                                                    alt=""
                                                    class="provider-drop-mark"
                                                    loading="lazy"
                                                />
                                            </div>
                                        ))}
                                    </div>
                                )
                            }
                        </div>
                    ))
                }
            </div>
        </div>
    </section>
</div>

<script>
    import { initHomeHero } from "./HomeHero.client";

    initHomeHero();

    const visuals = document.querySelectorAll("[data-animate='dissolve']");
    if (visuals.length && "IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
            (entries) => {
                for (const entry of entries) {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("is-visible");
                    } else {
                        entry.target.classList.remove("is-visible");
                    }
                }
            },
            { threshold: 0.3 },
        );
        for (const el of visuals) {
            observer.observe(el);
        }
    }
</script>

<script>
    const dropLogos = document.querySelectorAll(".provider-drop-logo");
    const randomInRange = (min: number, max: number) =>
        Math.random() * (max - min) + min;
    for (const logo of dropLogos) {
        if (!(logo instanceof HTMLElement)) continue;
        logo.style.setProperty("--drop-left", `${randomInRange(5, 90)}%`);
        logo.style.setProperty("--drop-delay", `${-randomInRange(0, 8)}s`);
        logo.style.setProperty("--drop-duration", `${randomInRange(8, 16)}s`);
        logo.style.setProperty("--drop-rotate", `${randomInRange(-28, 28)}deg`);
        logo.style.setProperty("--drop-end-rotate", `${randomInRange(-8, 8)}deg`);
        logo.style.setProperty("--drop-scale", `${randomInRange(0.85, 1.15)}`);
    }
</script>
