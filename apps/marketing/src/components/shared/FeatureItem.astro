---
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
const isEarthIcon = icon === "earth";
---

<article class="feature">
  <span class:list={["feature-icon", isEarthIcon && "feature-icon--earth"]} aria-hidden="true">
    {
      isEarthIcon ? (
        <svg viewBox="0 0 24 24" fill="none" focusable="false">
          <circle cx="12" cy="12" r="8.5" />
          <path d="M3.5 12h17" />
          <path d="M12 3.5c2.6 2.2 4.1 5.3 4.1 8.5S14.6 18.3 12 20.5" />
          <path d="M12 3.5C9.4 5.7 7.9 8.8 7.9 12s1.5 6.3 4.1 8.5" />
        </svg>
      ) : (
        icon
      )
    }
  </span>
  <div>
    <h2>{title}</h2>
    <p>{description}</p>
  </div>
</article>
