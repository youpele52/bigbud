---
import PlatformIcon from "./PlatformIcon.astro";
import DownloadAssetCard from "./DownloadAssetCard.astro";
import "./DownloadPlatformSection.css";

interface DownloadCard {
  label: string;
  format: string;
  assetSuffix: string;
}

interface Props {
  title: string;
  platform: "apple" | "windows" | "linux";
  cards: ReadonlyArray<DownloadCard>;
}

const { title, platform, cards } = Astro.props;
---

<section class="platform-section">
  <div class="platform-header">
    <PlatformIcon platform={platform} class="platform-icon" />
    <h2 class="platform-name">{title}</h2>
  </div>
  <slot name="beforeCards" />
  <div class="download-cards">
    {
      cards.map((card) => (
        <DownloadAssetCard
          label={card.label}
          format={card.format}
          assetSuffix={card.assetSuffix}
        />
      ))
    }
  </div>
  <slot name="afterCards" />
</section>
