---
import {
  APP_NAME,
  GITHUB_REPO_URL,
  X_PROFILE_URL,
  YOUTUBE_CHANNEL_URL,
} from "../constants/app";
import "./LayoutFooter.css";
---

<footer class="footer-shell">
  <div class="footer">
    <span class="footer-copy">
      <span class="footer-copy-year">&copy; {new Date().getFullYear()}</span>
      <a
        href="https://youpele.com"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Visit youpele.com"
      >
        <img src="/brand/pele.svg" alt="" aria-hidden="true" class="footer-copy-mark" />
      </a>
      <span>{APP_NAME}</span>
    </span>
    <div class="footer-links">
      <a
        href={YOUTUBE_CHANNEL_URL}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Visit bigbud on YouTube"
      >
        <svg
          class="footer-social-icon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            fill="currentColor"
            d="M23.5 6.2a3 3 0 0 0-2.1-2.12C19.53 3.58 12 3.58 12 3.58s-7.53 0-9.4.5A3 3 0 0 0 .5 6.2 31.2 31.2 0 0 0 0 12a31.2 31.2 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.12c1.87.5 9.4.5 9.4.5s7.53 0 9.4-.5a3 3 0 0 0 2.1-2.12A31.2 31.2 0 0 0 24 12a31.2 31.2 0 0 0-.5-5.8ZM9.6 15.6V8.4L15.86 12 9.6 15.6Z"
          />
        </svg>
      </a>
      <a
        href={X_PROFILE_URL}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Visit bigbud on X"
      >
        <svg
          class="footer-social-icon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            fill="currentColor"
            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.451-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"
          />
        </svg>
      </a>
      <a
        href={GITHUB_REPO_URL}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View bigbud on GitHub"
      >
        <svg
          class="footer-social-icon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            fill="currentColor"
            d="M12 2C6.48 2 2 6.58 2 12.24c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-1.04-.01-1.89-2.78.62-3.37-1.21-3.37-1.21-.46-1.19-1.11-1.5-1.11-1.5-.91-.64.06-.63.06-.63 1 .07 1.53 1.05 1.53 1.05.9 1.57 2.35 1.12 2.92.86.09-.67.35-1.12.64-1.38-2.22-.26-4.56-1.15-4.56-5.1 0-1.13.4-2.05 1.05-2.77-.1-.26-.46-1.32.1-2.75 0 0 .86-.28 2.75 1.06A9.31 9.31 0 0 1 12 6.9c.85 0 1.7.12 2.5.35 1.9-1.34 2.75-1.06 2.75-1.06.56 1.43.2 2.49.1 2.75.65.72 1.05 1.64 1.05 2.77 0 3.96-2.35 4.84-4.58 5.1.36.32.68.92.68 1.86 0 1.34-.01 2.42-.01 2.75 0 .27.18.59.69.49A10.27 10.27 0 0 0 22 12.24C22 6.58 17.52 2 12 2Z"
          />
        </svg>
      </a>
    </div>
  </div>
</footer>
