---
import { APP_NAME } from "../constants/app";
import {
  DEFAULT_METADATA,
  MARKETING_THEME_COLOR,
  OG_LOCALE,
  ROBOTS_CONTENT,
  TWITTER_CARD,
} from "../constants/seo";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  type?: "website";
}

const {
  title = DEFAULT_METADATA.title,
  description = DEFAULT_METADATA.description,
  image = DEFAULT_METADATA.image,
  imageAlt = DEFAULT_METADATA.imageAlt,
  noindex = false,
  type = DEFAULT_METADATA.type,
} = Astro.props;

const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.toString();
const metadataImage = image.startsWith("http")
  ? image
  : (Astro.site ? new URL(image, Astro.site) : new URL(image, Astro.url)).toString();
const robots = noindex ? ROBOTS_CONTENT.noindex : ROBOTS_CONTENT.index;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content={robots} />
<meta name="theme-color" content={MARKETING_THEME_COLOR} />
<meta name="application-name" content={APP_NAME} />
<meta name="apple-mobile-web-app-title" content={APP_NAME} />
<link rel="canonical" href={canonicalUrl} />
<meta property="og:site_name" content={APP_NAME} />
<meta property="og:locale" content={OG_LOCALE} />
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={metadataImage} />
<meta property="og:image:alt" content={imageAlt} />
<meta name="twitter:card" content={TWITTER_CARD} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={metadataImage} />
<meta name="twitter:image:alt" content={imageAlt} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap"
  rel="stylesheet"
/>
<link rel="icon" href="/favicon.ico" sizes="48x48" />
<link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
<link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
