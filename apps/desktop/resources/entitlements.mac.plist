<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Allow JIT compilation (required by Electron's V8 engine) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Allow loading third-party libraries not signed by the same team.
         Required for native Node.js modules (node-pty, msgpackr, etc.). -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Allow microphone access for STT voice transcription -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- Allow unsigned executable memory for native addon compatibility.
         Required by some native Node.js modules loaded at runtime. -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
  </dict>
</plist>
